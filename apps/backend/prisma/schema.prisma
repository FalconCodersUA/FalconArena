generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  TEAM
  JURY
  ORGANIZER
}

enum TournamentStatus {
  DRAFT
  REGISTRATION
  RUNNING
  FINISHED
}

enum RoundStatus {
  DRAFT
  ACTIVE
  SUBMISSION_CLOSED
  EVALUATED
}

enum SubmissionStatus {
  DRAFT
  SUBMITTED
  LOCKED
}

enum AnnouncementAudience {
  ALL
  TEAM
  JURY
  ADMIN
  ORGANIZER
}

enum NotificationAudience {
  ALL
  TEAM
  JURY
  ADMIN
  ORGANIZER
  USER
}

enum NotificationType {
  REGISTRATION_STARTED
  ROUND_STARTED
  SUBMISSION_RECEIVED
  DEADLINE_REMINDER
  SUBMISSION_CLOSED
  GENERAL
}

enum TournamentScheduleEventType {
  ROUND
  CONSULTATION
  DEADLINE
  ANNOUNCEMENT
  OTHER
}

model User {
  id              String                 @id @default(cuid())
  email           String                 @unique
  fullName        String
  passwordHash    String
  role            Role                   @default(TEAM)
  settings        UserSettings?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  createdTournaments Tournament[]        @relation("TournamentCreatedBy")
  captainTeams    Team[]                 @relation("TeamCaptain")
  juryAssignments EvaluationAssignment[]
  evaluations     Evaluation[]
  notifications   Notification[]         @relation("NotificationUser")
  notificationReadStates NotificationReadState[]
  createdDirectConversations DirectConversation[] @relation("ConversationCreatedBy")
  directConversationParticipants DirectConversationParticipant[] @relation("ConversationParticipantUser")
  sentDirectMessages DirectMessage[] @relation("DirectMessageSender")
  auditLogs       AuditLog[]             @relation("AuditLogActor")
}

model UserSettings {
  userId                 String   @id
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatarUrl              String?
  userName               String?
  dateOfBirth            DateTime?
  presentAddress         String?
  permanentAddress       String?
  city                   String?
  postalCode             String?
  country                String?
  interfaceLanguage      String?
  timeZone               String?
  lastAnnouncementsReadAt DateTime?
  notifyAnnouncements    Boolean  @default(true)
  notifyReviews          Boolean  @default(false)
  notifyMessages         Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model Tournament {
  id                 String           @id @default(cuid())
  title              String
  description        String?
  startsAt           DateTime?
  registrationOpenAt DateTime
  registrationCloseAt DateTime
  maxTeams           Int?
  status             TournamentStatus @default(DRAFT)
  createdById        String?
  createdBy          User?            @relation("TournamentCreatedBy", fields: [createdById], references: [id])
  teams              Team[]
  rounds             Round[]
  scheduleEvents     TournamentScheduleEvent[]
  certificateTemplate CertificateTemplate?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model Team {
  id            String       @id @default(cuid())
  tournamentId  String
  tournament    Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name          String
  captainId     String
  captain       User         @relation("TeamCaptain", fields: [captainId], references: [id])
  organization  String?
  contactHandle String?
  members       TeamMember[]
  submissions   Submission[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([tournamentId, name])
  @@unique([tournamentId, captainId])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId     String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  fullName  String
  email     String
  createdAt DateTime @default(now())

  @@unique([teamId, email])
}

model Round {
  id          String       @id @default(cuid())
  tournamentId String
  tournament  Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  sequence    Int
  title       String
  description String
  mustHave    Json?
  technologyRequirements Json?
  additionalMaterials Json?
  startsAt    DateTime
  deadlineAt  DateTime
  deadlineReminderSentAt DateTime?
  status      RoundStatus  @default(DRAFT)
  submissions Submission[]
  assignments EvaluationAssignment[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([tournamentId, sequence])
}

model Submission {
  id           String           @id @default(cuid())
  roundId      String
  round        Round            @relation(fields: [roundId], references: [id], onDelete: Cascade)
  teamId       String
  team         Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  repoUrl      String
  demoUrl      String
  liveDemoUrl  String?
  shortSummary String?
  status       SubmissionStatus @default(DRAFT)
  submittedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  assignments  EvaluationAssignment[]

  @@unique([roundId, teamId])
}

model EvaluationAssignment {
  id           String      @id @default(cuid())
  roundId      String
  round        Round       @relation(fields: [roundId], references: [id], onDelete: Cascade)
  submissionId String
  submission   Submission  @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  juryId       String
  jury         User        @relation(fields: [juryId], references: [id], onDelete: Cascade)
  evaluation   Evaluation?
  assignedAt   DateTime    @default(now())

  @@unique([submissionId, juryId])
}

model Evaluation {
  id           String               @id @default(cuid())
  assignmentId String               @unique
  assignment   EvaluationAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  juryId       String
  jury         User                 @relation(fields: [juryId], references: [id], onDelete: Cascade)
  scores       Json
  totalScore   Float
  comment      String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model Announcement {
  id          String               @id @default(cuid())
  title       String
  body        String
  audience    AnnouncementAudience @default(ALL)
  linkUrl     String?
  isPinned    Boolean              @default(false)
  isActive    Boolean              @default(true)
  publishedAt DateTime             @default(now())
  createdById String
  updatedById String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
}

model Notification {
  id        String               @id @default(cuid())
  type      NotificationType     @default(GENERAL)
  audience  NotificationAudience @default(ALL)
  userId    String?
  user      User?                @relation("NotificationUser", fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  linkUrl   String?
  createdAt DateTime             @default(now())
  readStates NotificationReadState[]

  @@index([audience, createdAt])
  @@index([userId, createdAt])
}

model NotificationReadState {
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt         DateTime     @default(now())

  @@id([notificationId, userId])
  @@index([userId, readAt])
}

model DirectConversation {
  id           String                        @id @default(cuid())
  createdById  String?
  createdBy    User?                         @relation("ConversationCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  participants DirectConversationParticipant[]
  messages     DirectMessage[]
  createdAt    DateTime                      @default(now())
  updatedAt    DateTime                      @updatedAt

  @@index([updatedAt])
}

model DirectConversationParticipant {
  id             String             @id @default(cuid())
  conversationId String
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User               @relation("ConversationParticipantUser", fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime?
  createdAt      DateTime           @default(now())

  @@unique([conversationId, userId])
  @@index([userId, createdAt])
}

model DirectMessage {
  id             String             @id @default(cuid())
  conversationId String
  conversation   DirectConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User               @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  body           String
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([conversationId, createdAt])
}

model TournamentScheduleEvent {
  id           String                      @id @default(cuid())
  tournamentId String
  tournament   Tournament                  @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  type         TournamentScheduleEventType @default(OTHER)
  startsAt     DateTime
  endsAt       DateTime?
  location     String?
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  @@index([tournamentId, startsAt])
}

model CertificateTemplate {
  id          String     @id @default(cuid())
  tournamentId String    @unique
  tournament  Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  name        String     @default("Основний шаблон")
  title       String
  subtitle    String?
  body        String
  footer      String?
  signerName  String?
  signerRole  String?
  accentColor String     @default("#5E17EB")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model SystemIntegrationSettings {
  id                           String   @id @default("default")
  googleSheetsWebhookUrl       String?
  googleSheetsWebhookSecret    String?
  googleSheetsDefaultSheetName String?
  googleSheetsLastCheckedAt    DateTime?
  googleSheetsLastCheckStatus  String?
  googleSheetsLastCheckMessage String?
  emailNotificationsEnabled    Boolean?
  emailProvider                String?
  emailFrom                    String?
  emailReplyTo                 String?
  resendApiKey                 String?
  emailLastCheckedAt           DateTime?
  emailLastCheckStatus         String?
  emailLastCheckMessage        String?
  notifyRegistrationStarted    Boolean?
  notifyRoundStarted           Boolean?
  notifySubmissionReceived     Boolean?
  notifyDeadlineReminder       Boolean?
  notifySubmissionClosed       Boolean?
  minTeamMembers               Int?
  maxTeamMembers               Int?
  defaultMinReviewersPerSubmission Int?
  defaultProjectTimeZone       String?
  hideTeamsUntilRegistrationClose Boolean?
  defaultTournamentMaxTeams    Int?
  defaultRegistrationWindowHours Int?
  defaultRoundDurationHours    Int?
  defaultTournamentDescription String?
  defaultRoundDescription      String?
  updatedByUserId              String?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actor       User?    @relation("AuditLogActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorRole   Role
  action      String
  entityType  String
  entityId    String?
  entityLabel String?
  tournamentId String?
  title       String
  description String
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([actorId, createdAt])
  @@index([tournamentId, createdAt])
}
