NODE_ENV=production
APP_DOMAIN=localhost

POSTGRES_DB=falconarena
POSTGRES_USER=falcon
POSTGRES_PASSWORD=change_me

BACKEND_PORT=4000
PRISMA_SYNC_MODE=dbpush

JWT_SECRET=change_me
VITE_API_URL=http://localhost
JOBS_WORKER_ENABLED=true
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=/app/storage
STORAGE_LOCAL_PUBLIC_PREFIX=/uploads
STORAGE_S3_ENDPOINT=
STORAGE_S3_REGION=auto
STORAGE_S3_BUCKET=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=
STORAGE_S3_PUBLIC_BASE_URL=
STORAGE_S3_KEY_PREFIX=falconarena
STORAGE_S3_FORCE_PATH_STYLE=true
EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@falconarena.local
EMAIL_REPLY_TO=team@falconarena.local
RESEND_API_KEY=
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_SECRET=
GOOGLE_SHEETS_DEFAULT_SHEET_NAME=

# These values can also be managed in /app/integrations via the ADMIN UI.
# Environment variables stay as fallback/bootstrap configuration.
